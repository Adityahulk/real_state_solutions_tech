{
  "name": "@rest/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @rest/shared-types build && next dev --turbopack -H 0.0.0.0 ${WEB_PORT:+-p $WEB_PORT}",
    "build": "pnpm --filter @rest/shared-types build && next build",
    "start": "next start -H 0.0.0.0 -p ${WEB_PORT:-3000}",
    "prod": "pnpm build && pnpm start",
    "lint": "next lint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@rest/shared-types": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.451.0",
    "next": "^15.0.0",
    "react-leaflet": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.3",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22.7.4",
    "@types/leaflet": "^1.9.12",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}

# =====================================================================
# .env.prod.example — copy to `.env.prod` next to docker-compose.prod.yml
# and fill in real values. The api + web containers both read this file
# via `env_file: .env.prod`.
# =====================================================================

# Required: DO Managed Postgres (must have postgis + pgcrypto + citext)
DATABASE_URL=postgresql://USER:PASS@host:25060/rest?sslmode=require

# Required: DO Managed Redis
REDIS_URL=rediss://default:PASS@host:25061

# Required: object storage (DO Spaces / AWS S3 / R2 — all S3 API)
S3_ENDPOINT=https://blr1.digitaloceanspaces.com
S3_REGION=blr1
S3_BUCKET=your-spaces-bucket
S3_ACCESS_KEY=
S3_SECRET_KEY=
# What the browser hits for signed reads — Spaces CDN URL is fine here.
S3_PUBLIC_BASE_URL=https://your-spaces-bucket.blr1.cdn.digitaloceanspaces.com

# Required: auth secrets — generate with `openssl rand -hex 32`
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
NEXTAUTH_SECRET=

# Required: the public origins (used by webhook callback URLs, redirects)
NEXTAUTH_URL=https://app.example.com
PUBLIC_API_URL=https://app.example.com
API_URL=http://api:4000

# Branding shown on letters / receipts
ORG_NAME=Your Builder Pvt Ltd
ORG_EMAIL=noreply@example.com

# Bootstrap super-admin — seed runs idempotently with this on first deploy
BOOTSTRAP_SUPERADMIN_EMAIL=admin@example.com
BOOTSTRAP_SUPERADMIN_PASSWORD=ChangeMe!123

# --- Production safety toggles ---
NODE_ENV=production
# Leave false in production. Set true ONLY if you genuinely need sandbox
# payment/esign auto-pay routes accessible (e.g. for a smoke test).
ALLOW_SANDBOX_WEBHOOKS=false
# Set RUN_SEED=false after the first deploy to skip the idempotent seed.
RUN_MIGRATIONS=true
RUN_SEED=true

# --- Third-party integrations (sandbox mode if blank) ---

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Digio e-sign
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=

# Mux video
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE_BASE64=

# Autodesk Platform Services
APS_CLIENT_ID=
APS_CLIENT_SECRET=
APS_BUCKET_PREFIX=

# Email + SMS
RESEND_API_KEY=
RESEND_FROM=noreply@example.com
MSG91_AUTH_KEY=

# Observability (your call)
SENTRY_DSN=

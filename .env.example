# --- Database ---
DATABASE_URL=postgresql://rest:rest@localhost:5432/rest_dev?schema=public

# --- Redis (queues + cache) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (R2 / S3 / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=rest-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/rest-dev

# --- Auth ---
JWT_SECRET=change-me-in-prod-min-32-chars-please-xxxxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-prod-min-32-chars-please-xxxxxxx

# --- API base (web -> api) ---
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Branding shown on letters/receipts ---
ORG_NAME=The Builder
ORG_EMAIL=noreply@example.com

# --- Third-party (sandbox keys; leave blank to run in sandbox mode) ---
APS_CLIENT_ID=
APS_CLIENT_SECRET=

# Razorpay — leave blank to use sandbox auto-pay (clicking the link marks paid)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Digio e-sign — leave blank to use sandbox auto-sign
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=

# Email — leave blank to skip outbound email
RESEND_API_KEY=
RESEND_FROM=noreply@example.com

MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE_BASE64=

# APS (Autodesk Platform Services) for DWG → SVF2 translation
APS_CLIENT_ID=
APS_CLIENT_SECRET=
APS_BUCKET_PREFIX=

MSG91_AUTH_KEY=
SENTRY_DSN=

# Public origin of the API (used by webhook callback URLs)
PUBLIC_API_URL=http://localhost:4000
